{
  "name": "claw-socket",
  "version": "0.1.0",
  "description": "Real-time WebSocket bridge that streams Claude Code events to any connected client",
  "author": "ractive",
  "license": "MIT",
  "keywords": [
    "claude",
    "claude-code",
    "websocket",
    "real-time",
    "events",
    "streaming",
    "mcp",
    "anthropic"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ractive/claw-socket.git"
  },
  "bugs": {
    "url": "https://github.com/ractive/claw-socket/issues"
  },
  "homepage": "https://github.com/ractive/claw-socket#readme",
  "engines": {
    "bun": ">=1.0"
  },
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "claw-socket": "src/index.ts"
  },
  "files": [
    "src/",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile claw-socket",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "export-spec": "bun run scripts/export-spec.ts",
    "patch-docs": "bun run scripts/patch-docs.ts",
    "check": "bunx biome check --write src/ test/ scripts/ && bun run typecheck && bun test && bun audit"
  },
  "dependencies": {
    "zod": "^3.24",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/bun": "1.3.11"
  },
  "peerDependencies": {
    "typescript": "^5 || ^6"
  }
}
